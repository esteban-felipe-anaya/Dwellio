# Dwellio runtime config (loaded by flutter_dotenv at startup).
# Base URL of the FastAPI backend. No trailing slash.
#   Web / desktop / iOS simulator : http://localhost:8000
#   Android emulator              : http://10.0.2.2:8000
#   Physical device               : http://<your-machine-LAN-ip>:8000
DWELLIO_API_BASE_URL=http://192.168.6.124:8000

# Inject artificial latency + occasional failures (dev only): true | false
DWELLIO_SIMULATE_NETWORK=true
